{
  "name": "claude-code-secure-baseline",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "vscode",
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "extensions": [
        "timonwong.shellcheck",
        "redhat.vscode-yaml"
      ]
    }
  },
  "containerEnv": {
    "CLAUDE_CODE_CONFIG_DIR": "/workspace/.claude"
  },
  "runArgs": [
    "--cap-drop=ALL",
    "--security-opt=no-new-privileges"
  ]
}
