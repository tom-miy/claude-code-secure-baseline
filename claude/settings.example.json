{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": [
        "./.env",
        "./.env.*",
        "./secrets/**",
        "./config/credentials.json",
        "./**/*.pem",
        "./**/*.key",
        "~/.aws/credentials",
        "~/.aws/config",
        "~/.aws/sso/cache/**",
        "~/.config/gcloud/**",
        "~/.kube/config",
        "~/.docker/config.json",
        "~/.netrc",
        "~/.npmrc",
        "~/.pypirc",
        "~/.gnupg/**",
        "~/.ssh/**",
        "~/.ssh/id_*",
        "~/.ssh/*_key"
      ],
      "denyWrite": [
        "/etc",
        "/usr/local/bin",
        "~/.ssh/**",
        "~/.aws/**",
        "~/.config/gcloud/**",
        "~/.kube/**",
        "~/.docker/**",
        "~/.gnupg/**"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.githubusercontent.com",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "files.pythonhosted.org"
      ],
      "deniedDomains": [
        "*.prod.example.com",
        "*.production.example.com"
      ]
    }
  },
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push *)",
      "Bash(chmod 777 *)",
      "Bash(*.env*)",
      "Bash(*secrets/*)",
      "Bash(*credentials.json*)",
      "Bash(*.pem*)",
      "Bash(*.key*)",
      "Bash(*.aws/credentials*)",
      "Bash(*.aws/config*)",
      "Bash(*.aws/sso/cache*)",
      "Bash(*.config/gcloud*)",
      "Bash(*.kube/config*)",
      "Bash(*.docker/config.json*)",
      "Bash(*.netrc*)",
      "Bash(*.npmrc*)",
      "Bash(*.pypirc*)",
      "Bash(*.gnupg*)",
      "Bash(*.ssh*)",
      "Bash(*prod*)",
      "Bash(*production*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/config)",
      "Read(~/.aws/sso/cache/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/config)",
      "Read(~/.docker/config.json)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.gnupg/**)",
      "Read(~/.ssh/**)",
      "Read(~/.ssh/id_*)",
      "Read(~/.ssh/*_key)",
      "WebFetch(domain:*.prod.example.com)",
      "WebFetch(domain:*.production.example.com)"
    ],
    "ask": [
      "Bash(npm publish *)"
    ],
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(npm run lint)",
      "Bash(npm test *)",
      "Bash(jq *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/validate-command.sh",
            "args": []
          }
        ]
      }
    ]
  }
}
